{
  "name": "healthslot-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Root workspace for HealthSlot backend, frontend, and admin apps",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "backend",
    "frontend",
    "admin"
  ],
  "scripts": {
    "install:all": "node scripts/install-all.js",
    "dev": "node scripts/dev.js",
    "build:all": "node scripts/build-all.js",
    "lint:all": "node scripts/lint-all.js",
    "test:all": "node scripts/test-all.js",
    "clean": "node scripts/clean.js",
    "reinstall": "npm run clean && npm run install:all"
  },
  "devDependencies": {
    "vite": "^6.3.5"
  }
}
